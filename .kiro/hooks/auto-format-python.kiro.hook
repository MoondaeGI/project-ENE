{
  "enabled": true,
  "name": "Auto Format Python on Save",
  "description": "Python 파일이 저장될 때 black 포맷터를 자동으로 실행하여 코드 스타일을 통일합니다",
  "version": "1.0.0",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "src/**/*.py",
      "tests/**/*.py"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "black src/ tests/ --line-length 100 --target-version py313",
    "timeout": 30
  }
}